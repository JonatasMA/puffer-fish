{
    "name": "puffer-fish",
    "displayName": "Puffer Fish",
    "description": "Ajuda a trocar os padrões antigos do CRM para os padrões novos",
    "version": "0.0.30",
    "engines": {
        "vscode": "^1.78.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/src/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "extension.pufferFish.replaceConteinerGet",
                "title": "PufferFish: Replace Conteiner::Get"
            },
            {
                "command": "extension.pufferFish.replaceConteinerEntidade",
                "title": "PufferFish: Replace ConteinerEntidade::getInstancia"
            },
            {
                "command": "extension.pufferFish.replaceGetCampo",
                "title": "PufferFish: Replace getCampo"
            },
            {
                "command": "extension.pufferFish.replaceSetCampo",
                "title": "PufferFish: Replace setCampo"
            },
            {
                "command": "extension.pufferFish.replaceAllPatterns",
                "title": "PufferFish: Replace All"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/vscode": "^1.78.0",
        "typescript": "^4.9.4",
        "vsce": "^2.15.0"
    },
    "tasks": [
        {
            "type": "npm",
            "script": "compile",
            "group": "build",
            "problemMatcher": [],
            "label": "npm: compile"
        }
    ],
    "homepage": "https://github.com/JonatasMA/puffer-fish/blob/main/README.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/JonatasMA/puffer-fish.git"
    }
}